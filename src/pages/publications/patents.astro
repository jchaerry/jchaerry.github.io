---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

const patents = (await getCollection('patents')).sort(sortItemsByDateDesc);
---

<BaseLayout title="Patents" showHeader={false}>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-12 font-serif text-3xl italic text-theme-foreground border-b pb-4 border-gray-200 dark:border-gray-800">
      Patents
    </h1>

    {patents.length > 0 ? (
      <div class="flex flex-col gap-10">
        {patents.map((patent) => (
          <div class="flex flex-col relative border-l-2 border-gray-200 dark:border-gray-800 pl-5 hover:border-gray-400 dark:hover:border-gray-500 transition-colors">
            
            {/* 상태 뱃지 (보라색 테마 - Pending 등 표시) */}
            {patent.data.note && (
              <div class="mb-2">
                <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 dark:text-purple-300 dark:bg-purple-900/30 rounded">
                  {patent.data.note}
                </span>
              </div>
            )}

            {/* 특허명 */}
            <h2 class="font-serif text-lg font-bold text-gray-900 dark:text-gray-100 mb-1.5 leading-tight">
              {patent.data.title}
            </h2>
            
            {/* 발명자 */}
            <p class="text-[14px] text-gray-600 dark:text-gray-400 mb-1 leading-relaxed">
              {patent.data.inventors}
            </p>
            
            {/* 국가 및 출원/등록 번호 */}
            {(patent.data.country || patent.data.patentNumber) && (
              <p class="text-[13px] italic text-gray-400 dark:text-gray-500 mb-3">
                {patent.data.country && <span>[{patent.data.country}] </span>}
                {patent.data.patentNumber && <span>App. No. {patent.data.patentNumber}</span>}
              </p>
            )}
            
            {/* 하이퍼링크 (키프리스 등 링크가 있을 때만 표시) */}
            {patent.data.url && (
              <div class="mt-1">
                <a 
                  href={patent.data.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="text-xs font-medium text-gray-400 hover:text-black dark:hover:text-white transition-colors underline underline-offset-4 decoration-gray-200 dark:decoration-gray-800"
                >
                  View Patent ↗
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <p class="text-sm text-gray-400 italic">No patents published yet.</p>
    )}
  </div>
</BaseLayout>